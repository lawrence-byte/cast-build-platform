{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CAST Build brand manifest",
  "type": "object",
  "required": ["roles", "rules"],
  "properties": {
    "$schema": { "type": "string" },
    "_comment": { "type": "string" },
    "_lastReviewed": { "type": "string", "format": "date" },
    "_owner": { "type": "string" },
    "roles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["file", "description", "format", "useFor"],
        "properties": {
          "file": { "type": "string", "pattern": "^[A-Za-z0-9._-]+\\.(svg|png|jpg|jpeg)$" },
          "description": { "type": "string" },
          "format": { "type": "string", "enum": ["svg", "png", "jpg", "jpeg"] },
          "scope": { "type": "string" },
          "useFor": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        }
      }
    },
    "deprecated": {
      "type": "object",
      "properties": {
        "_note": { "type": "string" },
        "files": { "type": "array", "items": { "type": "string" } }
      }
    },
    "rules": { "type": "array", "items": { "type": "string" } }
  }
}
