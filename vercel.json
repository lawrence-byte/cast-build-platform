{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/projects",
      "destination": "/projects.html"
    },
    {
      "source": "/procore",
      "destination": "/procore.html"
    },
    {
      "source": "/document-tools",
      "destination": "/document-tools.html"
    },
    {
      "source": "/projects/alum-budget",
      "destination": "/projects/alum-budget.html"
    },
    {
      "source": "/projects/alum-command-center",
      "destination": "/projects/alum-command-center.html"
    },
    {
      "source": "/projects/alum-schedule",
      "destination": "/projects/alum-schedule.html"
    },
    {
      "source": "/projects/alum-closeout",
      "destination": "/projects/alum-closeout.html"
    },
    {
      "source": "/projects/alum-accounting-tieout",
      "destination": "/projects/alum-accounting-tieout.html"
    },
    {
      "source": "/projects/alum-commitments",
      "destination": "/projects/alum-commitments.html"
    },
    {
      "source": "/projects/alum-budget-changes",
      "destination": "/projects/alum-budget-changes.html"
    },
    {
      "source": "/projects/alum-budget-forecast",
      "destination": "/projects/alum-budget-forecast.html"
    },
    {
      "source": "/projects/alum-dynamic-forecast",
      "destination": "/projects/alum-dynamic-forecast.html"
    },
    {
      "source": "/projects/alum-budget-modifications",
      "destination": "/projects/alum-budget-modifications.html"
    },
    {
      "source": "/projects/alum-open-items",
      "destination": "/projects/alum-open-items.html"
    },
    {
      "source": "/projects/alum-executive-report",
      "destination": "/projects/alum-executive-report.html"
    },
    {
      "source": "/projects/alum-document-intelligence",
      "destination": "/projects/alum-document-intelligence.html"
    },
    {
      "source": "/api/:path*",
      "destination": "/api-placeholder.json"
    },
    {
      "source": "/pricing-models",
      "destination": "/pricing-models.html"
    },
    {
      "source": "/projects/golden-hill",
      "destination": "/projects/golden-hill.html"
    },
    {
      "source": "/projects/overlook",
      "destination": "/projects/overlook.html"
    }
  ]
}
